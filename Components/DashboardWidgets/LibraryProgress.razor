@using StudentManagementSystemApp.Models

<div class="library-card">

	@{
		var totalCopies = Dashboard.TotalBooks;

		var availableCopies = Dashboard.AvailableBooks;

		var issuedCopies = totalCopies - availableCopies;

		var percent = Dashboard.LibraryUtilization;
	}

	<div class="library-header">

		<div>

			<h4>

				<i class="fas fa-book-open text-primary me-2"></i>

				Library Utilization

			</h4>

			<span>

				Current Library Status

			</span>

		</div>

		<div class="library-percent @GetBadgeClass()">

			@($"{percent:F0}%")

		</div>

	</div>

	<div class="progress-section">

		<div class="library-progress">

			<div class="library-fill"
				 style="width:@($"{percent}%")">
			</div>

		</div>

		<div class="progress-label">

			@issuedCopies of @totalCopies Copies Issued

		</div>

	</div>

	<div class="library-stats">

		<div class="stat-box">

			<i class="fas fa-layer-group text-primary"></i>

			<div>

				<span>Total Copies</span>

				<h5>@totalCopies</h5>

			</div>

		</div>

		<div class="stat-box">

			<i class="fas fa-book-reader text-danger"></i>

			<div>

				<span>Issued Copies</span>

				<h5>@issuedCopies</h5>

			</div>

		</div>

		<div class="stat-box">

			<i class="fas fa-check-circle text-success"></i>

			<div>

				<span>Available Copies</span>

				<h5>@availableCopies</h5>

			</div>

		</div>

	</div>

</div>

@code {

	[Parameter]
	public DashboardDto Dashboard { get; set; } = new();

	private string GetBadgeClass()
	{
		if (Dashboard.LibraryUtilization < 40)
			return "success";

		if (Dashboard.LibraryUtilization < 70)
			return "warning";

		return "danger";
	}

}