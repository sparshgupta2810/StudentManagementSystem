@using StudentManagementSystemApp.Models

<div class="department-card">

    @{
        var departments = Dashboard.DepartmentStudents
            .OrderByDescending(x => x.TotalStudents)
            .Take(5)
            .ToList();

        var totalStudents = Dashboard.DepartmentStudents.Sum(x => x.TotalStudents);

        var maxStudents = departments.Any()
            ? departments.Max(x => x.TotalStudents)
            : 1;
    }

    <!-- Header -->

    <div class="department-header">

        <div>

            <h4>
                <i class="fas fa-building me-2 text-primary"></i>
                Department Analytics
            </h4>

            <span>
                Top 5 Departments by Student Count
            </span>

        </div>

        <div class="department-total">

            <h3>@totalStudents</h3>

            <small>Total Students</small>

        </div>

    </div>

    <hr />

    @if (departments.Any())
    {
        @for (int i = 0; i < departments.Count; i++)
        {
            var item = departments[i];

            var percentage = totalStudents == 0
                ? 0
                : Math.Round((double)item.TotalStudents * 100 / totalStudents);

            var width = maxStudents == 0
                ? 0
                : item.TotalStudents * 100 / maxStudents;

            <div class="department-item">

                <div class="department-top">

                    <div class="department-name">

                        <span class="rank">

                            @(i + 1)

                        </span>

                        @item.Department

                    </div>

                    <div class="department-count">

                        @item.TotalStudents Students

                    </div>

                </div>

                <div class="progress modern-progress">

                    <div class="progress-bar"

                         style="width:@width%;
                                background:@GetColor(i);">

                    </div>

                </div>

                <div class="department-bottom">

                    <span>

                        @percentage%

                    </span>

                </div>

            </div>
        }
    }
    else
    {
        <div class="empty-state">

            <i class="fas fa-building fa-3x mb-3 text-muted"></i>

            <h5>No Data Available</h5>

            <p>
                Departments will appear here.
            </p>

        </div>
    }

    <div class="department-footer">

        <a href="/departments">

            View All Departments

            <i class="fas fa-arrow-right ms-2"></i>

        </a>

    </div>

</div>

@code{

    [Parameter]
    public DashboardDto Dashboard { get; set; } = new();

    private string GetColor(int index)
    {
        return index switch
        {
            0 => "linear-gradient(90deg,#4F46E5,#6366F1)",
            1 => "linear-gradient(90deg,#10B981,#34D399)",
            2 => "linear-gradient(90deg,#F59E0B,#FBBF24)",
            3 => "linear-gradient(90deg,#EF4444,#F87171)",
            _ => "linear-gradient(90deg,#06B6D4,#38BDF8)"
        };
    }

}