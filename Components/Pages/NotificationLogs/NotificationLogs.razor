@page "/notification-logs"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models.Notification

@attribute [Authorize(Roles = Roles.Admin)]

@inject NotificationService NotificationLogService

<PageTitle>Notification Logs</PageTitle>

<div class="card card-primary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title mb-2 mb-md-0">

                <i class="bi bi-envelope-check-fill"></i>

                Notification Logs

            </h3>

            <div class="d-flex align-items-center gap-2">

                <input class="form-control"
                       style="width:340px"
                       placeholder="Search Student, Email, Notification..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                <button class="btn btn-light"
                        @onclick="Refresh">

                    <i class="bi bi-arrow-clockwise"></i>

                    Refresh

                </button>

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center p-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Notification Logs...

                </p>

            </div>
        }
        else if (!logs.Any())
        {
            <div class="alert alert-warning">

                No Notification Logs Found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Date</th>

                            <th>Student</th>

                            <th>Email</th>

                            <th>Notification</th>

                            <th>Status</th>

                            <th>Error</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var log in logs)
                        {
                            <tr>

                                <td>

                                    <strong>

                                        @log.SentDate.ToString("dd MMM yyyy")

                                    </strong>

                                    <br/>

                                    <small class="text-muted">

                                        @log.SentDate.ToString("hh:mm tt")

                                    </small>

                                </td>

                                <td>

                                    @log.StudentName

                                </td>

                                <td>

                                    @log.Email

                                </td>

                                <td>

                                    @switch (log.NotificationType)
                                    {
                                        case "BookIssued":

                                            <span class="badge bg-success">

                                                📚 Book Issued

                                            </span>

                                            break;

                                        case "BookReturned":

                                            <span class="badge bg-primary">

                                                ↩ Book Returned

                                            </span>

                                            break;

                                        case "BookOverdue":

                                            <span class="badge bg-warning text-dark">

                                                ⚠ Overdue Reminder

                                            </span>

                                            break;

                                        default:

                                            <span class="badge bg-secondary">

                                                @log.NotificationType

                                            </span>

                                            break;
                                    }

                                </td>

                                <td>

                                    @if(log.Status=="Success")
                                    {
                                        <span class="badge bg-success">

                                            <i class="bi bi-check-circle-fill"></i>

                                            Success

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">

                                            <i class="bi bi-x-circle-fill"></i>

                                            Failed

                                        </span>
                                    }

                                </td>

                                <td>

                                    @if(string.IsNullOrWhiteSpace(log.ErrorMessage))
                                    {
                                        <span>-</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">

                                            @(log.ErrorMessage.Length>40
                                                ? log.ErrorMessage[..40]+"..."
                                                : log.ErrorMessage)

                                        </span>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code{

    private List<NotificationLog> logs = new();

    private bool loading = true;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        loading = true;

        StateHasChanged();

        var result =
            await NotificationLogService.GetPagedLogsAsync(
                CurrentPage,
                PageSize,
                string.IsNullOrWhiteSpace(searchText)
                    ? null
                    : searchText);

        logs = result.Items.ToList();

        TotalPages = result.TotalPages;

        TotalRecords = result.TotalRecords;

        loading = false;

        StateHasChanged();
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadLogs();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadLogs();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        CurrentPage = 1;

        await LoadLogs();
    }

    private async Task Refresh()
    {
        searchText = "";

        CurrentPage = 1;

        await LoadLogs();
    }

}