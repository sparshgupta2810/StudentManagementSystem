@page "/teachers"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize]

@inject TeacherService TeacherService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Teachers</PageTitle>

<div class="card card-primary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title mb-2 mb-md-0">

                <i class="bi bi-person-workspace"></i>

                Teachers

            </h3>

            <div class="d-flex align-items-center gap-2 flex-wrap">

                <input class="form-control"
                       style="width:320px"
                       placeholder="Search Teacher, Email, Department..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                <button class="btn btn-secondary"
                        @onclick="History">

                    <i class="bi bi-clock-history"></i>

                    Teacher History

                </button>

                @if (canManage)
                {
                    <button class="btn btn-light"
                            @onclick="AddTeacher">

                        <i class="bi bi-plus-circle"></i>

                        Add Teacher

                    </button>
                }

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center p-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Teachers...

                </p>

            </div>
        }
        else if (!teachers.Any())
        {
            <div class="alert alert-warning">

                No Teachers Found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Name</th>

                            <th>Department</th>

                            <th>Email</th>

                            <th>Phone</th>

                            <th>Qualification</th>

                            <th>Experience</th>

                            <th>Status</th>

                            @if (canManage)
                            {
                                <th >

                                    Action

                                </th>
                            }

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var teacher in teachers)
                        {
                            <tr>

                                <td class="w-25">

                                    <strong>

                                        @teacher.FirstName
                                        @teacher.MiddleName
                                        @teacher.LastName

                                    </strong>

                                </td>

                                <td>

                                    @teacher.DepartmentName

                                </td>

                                <td>

                                    @teacher.Email

                                </td>

                                <td>

                                    @teacher.PhoneNumber

                                </td>

                                <td>

                                    @teacher.Qualification

                                </td>

                                <td>

                                    @(teacher.Experience ?? 0) Years

                                </td>

                                <td>

                                    @if (teacher.IsActive)
                                    {
                                        <span class="badge bg-success">

                                            Active

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">

                                            Inactive

                                        </span>
                                    }

                                </td>

                                @if (canManage)
                                {
                                    <td class="w-25">

                                        <button class="btn btn-warning btn-sm "
                                                @onclick="() => EditTeacher(teacher.Id)">

                                            <i class="bi bi-pencil-square"></i>

                                            Edit

                                        </button>

                                        <button class="btn btn-danger btn-sm ms-2"
                                                @onclick="() => InactiveTeacher(teacher.Id)">

                                            <i class="bi bi-person-x-fill"></i>

                                            Remove

                                        </button>

                                    </td>
                                }

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<Teacher> teachers = new();

    private bool loading = true;

    private bool canManage;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        canManage =
            authState.User.IsInRole(Roles.Admin);

        await LoadTeachers();
    }

    private async Task LoadTeachers()
    {
        loading = true;

        StateHasChanged();

        var result = await TeacherService.GetPagedTeachersAsync(
            CurrentPage,
            PageSize,
            string.IsNullOrWhiteSpace(searchText)
                ? null
                : searchText);

        teachers = result.Items.ToList();

        TotalPages = result.TotalPages;

        TotalRecords = result.TotalRecords;

        loading = false;

        StateHasChanged();
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadTeachers();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadTeachers();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;

        CurrentPage = 1;

        await LoadTeachers();
    }

    private void AddTeacher()
    {
        Navigation.NavigateTo("/teachers/add");
    }

    private void EditTeacher(int id)
    {
        Navigation.NavigateTo($"/teachers/edit/{id}");
    }

    private void InactiveTeacher(int id)
    {
        Navigation.NavigateTo($"/teachers/inactive/{id}");
    }

    private void History()
    {
        Navigation.NavigateTo("/teachers/history");
    }

}