@page "/departments/edit/{Id:int}"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = Roles.Admin)]

@inject DepartmentService DepartmentService
@inject NavigationManager Navigation

<PageTitle>Edit Department</PageTitle>

<div class="card card-warning shadow">

    <div class="card-header">

        <h3 class="card-title">

            <i class="bi bi-pencil-square"></i>

            Edit Department

        </h3>

    </div>

    @if (loading)
    {
        <div class="card-body text-center p-5">

            <div class="spinner-border text-warning"></div>

            <p class="mt-3">

                Loading Department...

            </p>

        </div>
    }
    else if (department == null)
    {
        <div class="card-body">

            <div class="alert alert-danger">

                Department not found.

            </div>

        </div>
    }
    else
    {
        <EditForm Model="@department"
                  OnValidSubmit="UpdateDepartment">

            <DataAnnotationsValidator />

            <ValidationSummary class="text-danger" />

            <div class="card-body">

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-success">

                        <i class="bi bi-check-circle-fill"></i>

                        @message

                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger">

                        <i class="bi bi-exclamation-triangle-fill"></i>

                        @error

                    </div>
                }

                <div class="row">
                    <div class="col-md-4">

                        <div class="mb-3">

                            <label class="form-label">

                                Department Code

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="department.DepartmentCode" />

                            <ValidationMessage For="@(() => department.DepartmentCode)"
                                               class="text-danger" />

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">

                                Department Name

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="department.DepartmentName" />

                            <ValidationMessage For="@(() => department.DepartmentName)"
                                               class="text-danger" />

                        </div>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-12">

                        <div class="mb-3">

                            <label class="form-label">

                                Description

                            </label>

                            <InputTextArea class="form-control"
                                           rows="3"
                                           @bind-Value="department.Description" />

                        </div>

                    </div>

                </div>

            </div>

            <div class="card-footer">

                <button type="submit"
                        class="btn btn-warning"
                        disabled="@saving">

                    @if (saving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }

                    <i class="bi bi-save"></i>

                    Update

                </button>

                <button type="button"
                        class="btn btn-secondary ms-2"
                        @onclick="Back">

                    <i class="bi bi-arrow-left-circle"></i>

                    Back

                </button>

            </div>

        </EditForm>
    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Department? department;

    private bool loading = true;

    private bool saving;

    private string? message;

    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadDepartment();
    }

    private async Task LoadDepartment()
    {
        loading = true;

        department = await DepartmentService.GetDepartmentByIdAsync(Id);

        loading = false;
    }

    private async Task UpdateDepartment()
    {
        try
        {
            saving = true;

            message = string.Empty;
            error = string.Empty;

            await DepartmentService.UpdateDepartmentAsync(department!);

            message = "Department updated successfully.";

            await Task.Delay(800);

            Navigation.NavigateTo("/departments");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/departments");
    }

}