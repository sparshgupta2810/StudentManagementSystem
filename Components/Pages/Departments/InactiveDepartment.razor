@page "/departments/inactive/{Id:int}"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = Roles.Admin)]

@inject DepartmentService DepartmentService
@inject NavigationManager Navigation

<PageTitle>Inactive Department</PageTitle>

<div class="card card-danger shadow">

    <div class="card-header">

        <h3 class="card-title">

            <i class="bi bi-exclamation-triangle-fill"></i>

            Inactive Department

        </h3>

    </div>

    @if (loading)
    {
        <div class="card-body text-center p-5">

            <div class="spinner-border text-danger"></div>

            <p class="mt-3">

                Loading...

            </p>

        </div>
    }
    else if (department == null)
    {
        <div class="card-body">

            <div class="alert alert-danger">

                Department not found.

            </div>

        </div>
    }
    else
    {
        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="alert alert-success">

                    <i class="bi bi-check-circle-fill"></i>

                    @message

                </div>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">

                    <i class="bi bi-exclamation-circle-fill"></i>

                    @error

                </div>
            }

            <div class="alert alert-warning">

                <h5>

                    Are you sure you want to make this department inactive?

                </h5>

                <hr />

                <p>

                    <strong>Department Code :</strong>

                    @department.DepartmentCode

                </p>

                <p>

                    <strong>Department Name :</strong>

                    @department.DepartmentName

                </p>

                <p class="mb-0">

                    This department will move to the

                    <strong>Department History</strong>

                    page.

                </p>

            </div>

        </div>

        <div class="card-footer">

            <button class="btn btn-danger"
                    @onclick="MakeDepartmentInactive"
                    disabled="@saving">

                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }

                <i class="bi bi-x-circle"></i>

                Make Inactive

            </button>

            <button class="btn btn-secondary ms-2"
                    @onclick="Back">

                <i class="bi bi-arrow-left-circle"></i>

                Cancel

            </button>

        </div>
    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Department? department;

    private bool loading = true;

    private bool saving;

    private string? message;

    private string? error;

    protected override async Task OnInitializedAsync()
    {
        department = await DepartmentService.GetDepartmentByIdAsync(Id);

        loading = false;
    }

    private async Task MakeDepartmentInactive()
    {
        try
        {
            saving = true;

            await DepartmentService.InactivateDepartmentAsync(Id);

            message = "Department moved to history successfully.";

            await Task.Delay(800);

            Navigation.NavigateTo("/departments");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/departments");
    }

}