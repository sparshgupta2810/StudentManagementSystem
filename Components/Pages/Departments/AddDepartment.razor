@page "/departments/add"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = Roles.Admin)]

@inject DepartmentService DepartmentService
@inject NavigationManager Navigation

<PageTitle>Add Department</PageTitle>

<div class="card card-success shadow">

    <div class="card-header">

        <h3 class="card-title">

            <i class="bi bi-building-add"></i>

            Add Department

        </h3>

    </div>

    <EditForm Model="@department"
              OnValidSubmit="SaveDepartment">

        <DataAnnotationsValidator />

        <ValidationSummary class="text-danger" />

        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="alert alert-success">

                    <i class="bi bi-check-circle-fill"></i>

                    @message

                </div>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">

                    <i class="bi bi-exclamation-triangle-fill"></i>

                    @error

                </div>
            }

            <div class="row">

                <div class="col-md-4">

                    <div class="mb-3">

                        <label class="form-label">

                            Department Code

                        </label>

                        <InputText class="form-control"
                                   @bind-Value="department.DepartmentCode" />

                        <ValidationMessage For="@(() => department.DepartmentCode)"
                                           class="text-danger" />

                    </div>

                </div>

                <div class="col-md-8">

                    <div class="mb-3">

                        <label class="form-label">

                            Department Name

                        </label>

                        <InputText class="form-control"
                                   @bind-Value="department.DepartmentName" />

                        <ValidationMessage For="@(() => department.DepartmentName)"
                                           class="text-danger" />

                    </div>

                </div>

            </div>

            <div class="row">

                <div class="col-md-12">

                    <div class="mb-3">

                        <label class="form-label">

                            Description

                        </label>

                        <InputTextArea class="form-control"
                                       rows="3"
                                       @bind-Value="department.Description" />

                    </div>

                </div>

            </div>

        </div>

        <div class="card-footer">

            <button type="submit"
                    class="btn btn-success"
                    disabled="@saving">

                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }

                <i class="bi bi-check-circle"></i>

                Save

            </button>

            <button type="button"
                    class="btn btn-secondary ms-2"
                    @onclick="Back">

                <i class="bi bi-arrow-left-circle"></i>

                Back

            </button>

            <button type="reset"
                    class="btn btn-warning ms-2">

                <i class="bi bi-arrow-clockwise"></i>

                Reset

            </button>

        </div>

    </EditForm>

</div>

@code {

    private Department department = new()
    {
        IsActive = true
    };

    private bool saving;

    private string? message;

    private string? error;

    private async Task SaveDepartment()
    {
        try
        {
            saving = true;

            message = string.Empty;
            error = string.Empty;

            await DepartmentService.AddDepartmentAsync(department);

            message = "Department added successfully.";

            await Task.Delay(800);

            Navigation.NavigateTo("/departments");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/departments");
    }

}