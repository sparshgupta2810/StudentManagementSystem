@page "/departments"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize]

@inject DepartmentService DepartmentService
@inject NavigationManager Navigation

<PageTitle>Departments</PageTitle>

<div class="card card-primary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title mb-2 mb-md-0">

                <i class="bi bi-building"></i>

                Departments

            </h3>

            <div class="d-flex align-items-center gap-2 flex-wrap">

                <input class="form-control"
                       style="width:280px"
                       placeholder="Search Department..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                <button class="btn btn-secondary"
                        @onclick="History">

                    <i class="bi bi-clock-history"></i>

                    Department History

                </button>

                <AuthorizeView Roles="@Roles.Admin">

                    <button class="btn btn-light"
                            @onclick="AddDepartment">

                        <i class="bi bi-plus-circle"></i>

                        Add Department

                    </button>

                </AuthorizeView>

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center p-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">
                    Loading Departments...
                </p>

            </div>
        }
        else if (!departments.Any())
        {
            <div class="alert alert-warning">

                No Departments Found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th style="width:170px">Code</th>

                            <th>Department Name</th>

                            <AuthorizeView Roles="@Roles.Admin">

                                <th style="width:120px">Status</th>

                                <th style="width:180px">Action</th>

                            </AuthorizeView>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in departments)
                        {
                            <tr>

                                <td>

                                    <span class="badge bg-primary">

                                        @item.DepartmentCode

                                    </span>

                                </td>

                                <td>

                                    @item.DepartmentName

                                </td>

                                <AuthorizeView Roles="@Roles.Admin">

                                    <td>

                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">

                                                Active

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">

                                                Inactive

                                            </span>
                                        }

                                    </td>

                                    <td>

                                        <button class="btn btn-warning btn-sm"
                                                @onclick="() => EditDepartment(item.Id)">

                                            <i class="bi bi-pencil-square"></i>

                                            Edit

                                        </button>

                                        <button class="btn btn-danger btn-sm ms-2"
                                                @onclick="() => InactiveDepartment(item.Id)">

                                            <i class="bi bi-x-circle"></i>

                                            Remove

                                        </button>

                                    </td>

                                </AuthorizeView>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<Department> departments = new();

    private bool loading;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDepartments();
    }

    private async Task LoadDepartments()
    {
        loading = true;

        StateHasChanged();

        var result = await DepartmentService.GetPagedDepartmentsAsync(
            CurrentPage,
            PageSize,
            string.IsNullOrWhiteSpace(searchText)
                ? null
                : searchText);

        departments = result.Items.ToList();

        TotalPages = result.TotalPages;

        TotalRecords = result.TotalRecords;

        loading = false;
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadDepartments();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadDepartments();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        CurrentPage = 1;

        await LoadDepartments();
    }

    private void AddDepartment()
    {
        Navigation.NavigateTo("/departments/add");
    }

    private void EditDepartment(int id)
    {
        Navigation.NavigateTo($"/departments/edit/{id}");
    }

    private void InactiveDepartment(int id)
    {
        Navigation.NavigateTo($"/departments/inactive/{id}");
    }

    private void History()
    {
        Navigation.NavigateTo("/departments/history");
    }

}