@page "/departments/history"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize]

@inject DepartmentService DepartmentService
@inject NavigationManager Navigation

<PageTitle>Department History</PageTitle>

<div class="card card-secondary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title">

                <i class="bi bi-clock-history"></i>

                Department History

            </h3>

            <div class="d-flex align-items-center gap-2">

                <input class="form-control"
                       style="width:300px"
                       placeholder="Search Department..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                <button class="btn btn-light"
                        @onclick="Back">

                    <i class="bi bi-arrow-left"></i>

                    Active Departments

                </button>

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center p-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Department History...

                </p>

            </div>
        }
        else if (!departments.Any())
        {
            <div class="alert alert-success">

                No inactive departments found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover">

                    <thead class="table-light">

                        <tr>

                            <th style="width:180px">Department Code</th>

                            <th>Department Name</th>

                            <AuthorizeView Roles="@Roles.Admin">

                                <th style="width:120px">Status</th>

                                <th style="width:180px">Action</th>

                            </AuthorizeView>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in departments)
                        {
                            <tr>

                                <td>

                                    <span class="badge bg-primary">

                                        @item.DepartmentCode

                                    </span>

                                </td>

                                <td>

                                    @item.DepartmentName

                                </td>

                                <AuthorizeView Roles="@Roles.Admin">

                                    <td>

                                        <span class="badge bg-danger">

                                            Inactive

                                        </span>

                                    </td>

                                    <td>

                                        <button class="btn btn-success btn-sm"
                                            @onclick="() => RestoreDepartment(item.Id)">

                                            <i class="bi bi-arrow-counterclockwise"></i>

                                            Restore

                                        </button>

                                    </td>
                                </AuthorizeView>    

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<Department> departments = new();

    private bool loading = true;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        loading = true;

        StateHasChanged();

        var result = await DepartmentService.GetPagedDepartmentHistoryAsync(
            CurrentPage,
            PageSize,
            string.IsNullOrWhiteSpace(searchText)
                ? null
                : searchText);

        departments = result.Items.ToList();

        TotalPages = result.TotalPages;

        TotalRecords = result.TotalRecords;

        loading = false;

        StateHasChanged();
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadHistory();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadHistory();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        CurrentPage = 1;

        await LoadHistory();
    }

    private async Task RestoreDepartment(int id)
    {
        if (await DepartmentService.RestoreDepartmentAsync(id))
        {
            await LoadHistory();
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/departments");
    }

}