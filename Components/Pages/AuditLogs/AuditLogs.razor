@page "/auditlogs" 

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services
@using StudentManagementSystemApp.Interfaces

@attribute [Authorize(Roles = Roles.Admin)]


@inject IAuditLogService AuditLogService

<PageTitle>Audit Logs</PageTitle>

<div class="card card-primary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title">

                <i class="bi bi-journal-text"></i>

                Audit Logs

            </h3>

            <div class="d-flex">

                <input class="form-control me-2"
                       style="width:320px"
                       placeholder="Search User, Module, Action..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                <button class="btn btn-light"
                        @onclick="LoadAuditLogs">

                    <i class="bi bi-arrow-clockwise"></i>

                    Refresh

                </button>

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center py-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Audit Logs...

                </p>

            </div>
        }
        else if (!auditLogs.Any())
        {
            <div class="alert alert-warning">

                <i class="bi bi-exclamation-circle-fill"></i>

                No audit records found.

            </div>
        }
        else
        {

            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th width="170">

                                Date

                            </th>

                            <th>

                                User

                            </th>

                            <th width="100">

                                Role

                            </th>

                            <th width="120">

                                Module

                            </th>

                            <th width="110">

                                Action

                            </th>

                            <th>

                                Entity

                            </th>

                            <th>

                                Details

                            </th>

                            <th width="90">

                                View

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                    @foreach (var log in auditLogs)
{
    <tr>

        <td>

            @log.CreatedDate.ToString("dd MMM yyyy")

            <br />

            <small class="text-muted">

                @log.CreatedDate.ToString("hh:mm tt")

            </small>

        </td>

        <td>

            <strong>

                @log.FullName

            </strong>

            <br />

            <small class="text-muted">

                @log.UserName

            </small>

        </td>

        <td>

            @switch (log.RoleName)
            {
                case "Admin":

                    <span class="badge bg-danger">

                        Admin

                    </span>

                    break;

                case "Teacher":

                    <span class="badge bg-primary">

                        Teacher

                    </span>

                    break;

                case "Librarian":

                    <span class="badge bg-success">

                        Librarian

                    </span>

                    break;

                default:

                    <span class="badge bg-secondary">

                        @log.RoleName

                    </span>

                    break;
            }

        </td>

        <td>

            @switch (log.ModuleName)
            {
                case "Student":

                    <span class="badge bg-primary">

                        Student

                    </span>

                    break;

                case "Teacher":

                    <span class="badge bg-info">

                        Teacher

                    </span>

                    break;

                case "Department":

                    <span class="badge bg-success">

                        Department

                    </span>

                    break;

                case "Subject":

                    <span class="badge bg-warning text-dark">

                        Subject

                    </span>

                    break;

                case "Book":

                    <span class="badge bg-secondary">

                        Book

                    </span>

                    break;

                case "BookIssue":

                    <span class="badge bg-dark">

                        Book Issue

                    </span>

                    break;

                case "Country":

                    <span class="badge bg-primary">

                        Country

                    </span>

                    break;

                case "UserManagement":

                    <span class="badge bg-danger">

                        Users

                    </span>

                    break;

                default:

                    <span class="badge bg-light text-dark">

                        @log.ModuleName

                    </span>

                    break;
            }

        </td>

        <td>

            @switch (log.ActionName)
            {
                case "Add":

                    <span class="badge bg-success">

                        Add

                    </span>

                    break;

                case "Update":

                    <span class="badge bg-warning text-dark">

                        Update

                    </span>

                    break;

                case "Delete":

                    <span class="badge bg-danger">

                        Delete

                    </span>

                    break;

                case "Restore":

                    <span class="badge bg-info">

                        Restore

                    </span>

                    break;

                case "Issue":

                    <span class="badge bg-primary">

                        Issue

                    </span>

                    break;

                case "Return":

                    <span class="badge bg-success">

                        Return

                    </span>

                    break;

                case "ChangeRole":

                    <span class="badge bg-dark">

                        Role

                    </span>

                    break;

                default:

                    <span class="badge bg-secondary">

                        @log.ActionName

                    </span>

                    break;
            }

        </td>

        <td>

            <strong>

                @log.EntityName

            </strong>

        </td>

        <td>

            @log.Details

        </td>

        <td>

            <button class="btn btn-primary btn-sm"
                    @onclick="() => ViewAudit(log)">

                <i class="bi bi-eye-fill"></i>

            </button>

        </td>

    </tr>
}

                    </tbody>

                </table>

            </div>

        }

    </div>

    <div class="card-footer">

            <Pagination
                CurrentPage="@currentPage"
                TotalPages="@totalPages"
                TotalRecords="@totalRecords"
                PageSize="@pageSize"
                OnPageChanged="PageChanged"
                OnPageSizeChanged="ChangePageSize" />

</div>

</div>
<AuditViewDrawer

    Audit="selectedAudit"

    Changes="auditChanges"

    OnClose="CloseModal" />

@code {

    private List<AuditLog> auditLogs = new();

    private AuditLog? selectedAudit;

    private List<AuditChange> auditChanges = new();

    private bool loading = true;

    private string searchText = string.Empty;

    private int currentPage = 1;

    private int pageSize = 10;

    private int totalPages;

    private int totalRecords;

    protected override async Task OnInitializedAsync()
    {
        await LoadAuditLogs();
    }

    private async Task ChangePageSize(int size)
{
    pageSize = size;
    currentPage = 1;

    await LoadAuditLogs();
}

    private async Task LoadAuditLogs()
    {
        loading = true;

        try
        {
            var result = await AuditLogService.GetPagedAsync(
                currentPage,
                pageSize,
                searchText);

            auditLogs = result.Items.ToList();

            totalRecords = result.TotalRecords;

            totalPages = result.TotalPages;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Search()
    {
        currentPage = 1;

        await LoadAuditLogs();
    }

    private async Task PageChanged(int page)
    {
        currentPage = page;

        await LoadAuditLogs();
    }

    private void ViewAudit(AuditLog log)
{
    selectedAudit = log;

    auditChanges.Clear();

    if (!string.IsNullOrWhiteSpace(log.OldValue))
    {
        auditChanges =
            System.Text.Json.JsonSerializer.Deserialize<List<AuditChange>>(log.OldValue)
            ?? new();
    }
}

    private void CloseModal()
    {
        selectedAudit = null;
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
{
    searchText = e.Value?.ToString() ?? "";

    currentPage = 1;

    await LoadAuditLogs();
}
} 