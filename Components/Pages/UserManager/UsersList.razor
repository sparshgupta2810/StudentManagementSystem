@page "/users"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = "Admin")]

@inject UserManagementService UserManagementService
@inject NavigationManager Navigation

<PageTitle>User Management</PageTitle>

<div class="card card-primary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title">

                <i class="bi bi-people-fill"></i>

                User Management

            </h3>

            <input class="form-control"
                   style="width:320px"
                   placeholder="Search Email, Name or Role..."
                   value="@searchText"
                   @oninput="OnSearchChanged" />

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center p-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Users...

                </p>

            </div>
        }
        else if (!users.Any())
        {
            <div class="alert alert-warning">

                No Users Found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>User Name</th>

                            <th>Full Name</th>

                            <th>Email</th>

                            <th>Current Role</th>

                            <th>Status</th>

                            <th width="150">

                                Action

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var user in users)
                        {

                            <tr>

                                <td>@user.UserName</td>

                                <td>@user.FullName</td>

                                <td>@user.Email</td>

                                <td>

                                    @switch (user.CurrentRole)
                                    {
                                        case "Admin":
                                            <span class="badge bg-danger">
                                                Admin
                                            </span>
                                            break;

                                        case "Teacher":
                                            <span class="badge bg-primary">
                                                Teacher
                                            </span>
                                            break;

                                        case "Librarian":
                                            <span class="badge bg-success">
                                                Librarian
                                            </span>
                                            break;

                                        default:
                                            <span class="badge bg-secondary">
                                                User
                                            </span>
                                            break;
                                    }

                                </td>

                                <td>

                                    @if (user.IsAdmin)
                                    {
                                        <span class="badge bg-warning text-dark">

                                            Protected

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">

                                            Editable

                                        </span>
                                    }

                                </td>

                                <td>

                                    @if (user.IsAdmin)
                                    {
                                        <button class="btn btn-secondary btn-sm"
                                                disabled>

                                            <i class="bi bi-lock-fill"></i>

                                            Protected

                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-warning btn-sm"
                                                @onclick="() => EditRole(user.Id)">

                                            <i class="bi bi-pencil-square"></i>

                                            Edit Role

                                        </button>
                                    }

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<UserManagementViewModel> users = new();

    private bool loading = true;

    private string searchText = string.Empty;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            loading = true;

            StateHasChanged();

            var result = await UserManagementService.GetPagedUsersAsync(
                CurrentPage,
                PageSize,
                string.IsNullOrWhiteSpace(searchText)
                    ? null
                    : searchText);

            users = result.Items.ToList();

            TotalPages = result.TotalPages;

            TotalRecords = result.TotalRecords;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);

            users = new();
        }
        finally
        {
            loading = false;

            StateHasChanged();
        }
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadUsers();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadUsers();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        CurrentPage = 1;

        await LoadUsers();
    }

    private void EditRole(string id)
    {
        Navigation.NavigateTo($"/users/edit/{id}");
    }

}