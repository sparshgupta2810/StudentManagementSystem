@page "/subjects/history"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = Roles.Admin)]

@inject SubjectService SubjectService
@inject NavigationManager Navigation

<PageTitle>Subject History</PageTitle>

<div class="card card-secondary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title">

                <i class="bi bi-clock-history"></i>

                Subject History

            </h3>

            <div class="d-flex align-items-center gap-2">

                <input class="form-control"
                       style="width:300px"
                       placeholder="Search Subject Code or Name..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                <button class="btn btn-light"
                        @onclick="Back">

                    <i class="bi bi-arrow-left"></i>

                    Active Subjects

                </button>

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center py-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Subject History...

                </p>

            </div>
        }
        else if (!subjects.Any())
        {
            <div class="alert alert-success">

                <i class="bi bi-check-circle-fill"></i>

                No inactive subjects found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th width="170">

                                Subject Code

                            </th>

                            <th>

                                Subject Name

                            </th>

                            <th width="120">

                                Status

                            </th>

                            <th width="140">

                                Action

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in subjects)
                        {
                            <tr>

                                <td>

                                    <span class="badge bg-primary">

                                        @item.SubjectCode

                                    </span>

                                </td>

                                <td>

                                    @item.SubjectName

                                </td>

                                <td>

                                    <span class="badge bg-danger">

                                        Inactive

                                    </span>

                                </td>

                                <td>

                                    <button class="btn btn-success  btn-sm"
                                            @onclick="() => RestoreSubject(item.Id)">

                                        <i class="bi bi-arrow-counterclockwise"></i>

                                        Restore

                                    </button>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<Subject> subjects = new();

    private bool loading = true;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        loading = true;

        StateHasChanged();

        try
        {
            var result = await SubjectService.GetPagedSubjectHistoryAsync(
                CurrentPage,
                PageSize,
                string.IsNullOrWhiteSpace(searchText)
                    ? null
                    : searchText);

            subjects = result.Items.ToList();

            TotalPages = result.TotalPages;

            TotalRecords = result.TotalRecords;
        }
        finally
        {
            loading = false;

            StateHasChanged();
        }
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadHistory();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadHistory();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        CurrentPage = 1;

        await LoadHistory();
    }

    private async Task RestoreSubject(int id)
    {
        var result = await SubjectService.RestoreSubjectAsync(id);

        if (result)
        {
            await LoadHistory();
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/subjects");
    }

}