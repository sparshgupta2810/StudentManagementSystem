@page "/bookissues"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize]

@inject BookIssueService BookIssueService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Book Issues</PageTitle>

<div class="card card-primary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title mb-2 mb-md-0">

                <i class="bi bi-journal-arrow-up"></i>

                Book Issues

            </h3>

            <div class="d-flex align-items-center gap-2 flex-wrap">

                <input class="form-control"
                       style="width:320px"
                       placeholder="Search Student / Registration / Book..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                @if (canManage)
                {
                    <button class="btn btn-secondary"
                            @onclick="History">

                        <i class="bi bi-clock-history"></i>

                        History

                    </button>

                    <button class="btn btn-light"
                            @onclick="IssueBook">

                        <i class="bi bi-plus-circle"></i>

                        Issue Book

                    </button>
                }

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center p-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Book Issues...

                </p>

            </div>
        }
        else if (!issues.Any())
        {
            <div class="alert alert-warning">

                No Books Currently Issued.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Registration No</th>

                            <th>Student</th>

                            <th>Book Code</th>

                            <th>Book Name</th>

                            <th>Issue Date</th>

                            <th>Due Date</th>

                            <th>Status</th>

                            @if (canManage)
                            {
                                <th width="120">

                                    Action

                                </th>
                            }

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in issues)
                        {

                            <tr class="@(item.DueDate.Date < DateTime.Today ? "table-danger" : "")">

                                <td>

                                    <span class="badge bg-primary">

                                        @item.RegistrationNo

                                    </span>

                                </td>

                                <td>

                                    @item.StudentName

                                </td>

                                <td>

                                    @item.BookCode

                                </td>

                                <td>

                                    @item.BookName

                                </td>

                                <td>

                                    @item.IssueDate.ToShortDateString()

                                </td>

                                <td>

                                    @if (item.DueDate.Date < DateTime.Today)
                                    {
                                        <span class="text-danger fw-bold">

                                            @item.DueDate.ToShortDateString()

                                        </span>

                                        <br />

                                        <small class="text-danger">

                                            @((DateTime.Today - item.DueDate.Date).Days)
                                            day(s) overdue

                                        </small>
                                    }
                                    else
                                    {
                                        @item.DueDate.ToShortDateString()
                                    }

                                </td>

                                <td>

                                    @if (item.DueDate.Date < DateTime.Today)
                                    {
                                        <span class="badge bg-danger">

                                            Overdue

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">

                                            @item.Status

                                        </span>
                                    }

                                </td>

                                @if (canManage)
                                {

                                    <td>

                                        <button class="btn btn-success btn-sm"
                                                @onclick="() => ReturnBook(item.Id)">

                                            <i class="bi bi-arrow-return-left"></i>

                                            Return

                                        </button>

                                    </td>

                                }

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<BookIssue> issues = new();

    private bool loading = true;

    private bool canManage = false;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        canManage =
            authState.User.IsInRole(Roles.Admin) ||
            authState.User.IsInRole(Roles.Librarian);

        await LoadBookIssues();
    }

    private async Task LoadBookIssues()
    {
        loading = true;

        StateHasChanged();

        try
        {
            var result = await BookIssueService.GetPagedIssuedBooksAsync(
                CurrentPage,
                PageSize,
                string.IsNullOrWhiteSpace(searchText)
                    ? null
                    : searchText);

            issues = result.Items.ToList();

            TotalPages = result.TotalPages;

            TotalRecords = result.TotalRecords;
        }
        catch
        {
            issues = new();
        }
        finally
        {
            loading = false;

            StateHasChanged();
        }
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadBookIssues();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadBookIssues();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        CurrentPage = 1;

        await LoadBookIssues();
    }

    private void IssueBook()
    {
        Navigation.NavigateTo("/bookissues/issue");
    }

    private void ReturnBook(int id)
    {
        Navigation.NavigateTo($"/bookissues/return/{id}");
    }

    private void History()
    {
        Navigation.NavigateTo("/bookissues/history");
    }

}