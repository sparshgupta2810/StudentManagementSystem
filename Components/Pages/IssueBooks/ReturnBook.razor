@page "/bookissues/return/{Id:int}"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = $"{Roles.Admin},{Roles.Librarian}")]

@inject BookIssueService BookIssueService
@inject NavigationManager Navigation

<PageTitle>Return Book</PageTitle>

<div class="card card-success shadow">

    <div class="card-header">

        <h3 class="card-title">

            <i class="bi bi-arrow-return-left"></i>

            Return Book

        </h3>

    </div>

    @if (loading)
    {
        <div class="card-body text-center p-5">

            <div class="spinner-border text-success"></div>

            <p class="mt-3">

                Loading Book Issue...

            </p>

        </div>
    }
    else if (issue == null)
    {
        <div class="card-body">

            <div class="alert alert-danger">

                Book Issue not found.

            </div>

        </div>
    }
    else
    {

        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="alert alert-success">

                    <i class="bi bi-check-circle-fill"></i>

                    @message

                </div>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">

                    <i class="bi bi-exclamation-triangle-fill"></i>

                    @error

                </div>
            }

            <div class="alert alert-warning">

                <h5>

                    Are you sure you want to return this book?

                </h5>

                <hr />

                <p>

                    <strong>Registration No :</strong>

                    @issue.RegistrationNo

                </p>

                <p>

                    <strong>Student :</strong>

                    @issue.StudentName

                </p>

                <p>

                    <strong>Book :</strong>

                    @issue.BookCode - @issue.BookName

                </p>

                <p>

                    <strong>Issue Date :</strong>

                    @issue.IssueDate.ToShortDateString()

                </p>

                <p>

                    <strong>Due Date :</strong>

                    @issue.DueDate.ToShortDateString()

                </p>

                <hr />

                <p class="text-success mb-0">

                    Returning this book will increase the available copies automatically.

                </p>

            </div>

        </div>

        <div class="card-footer">

            <button class="btn btn-success"
                    @onclick="ReturnBookDetails"
                    disabled="@saving">

                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }

                <i class="bi bi-check-circle"></i>

                Return Book

            </button>

            <button class="btn btn-secondary ms-2"
                    @onclick="Back">

                <i class="bi bi-arrow-left-circle"></i>

                Cancel

            </button>

        </div>

    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private BookIssue? issue;

    private bool loading = true;

    private bool saving;

    private string? message;

    private string? error;

    protected override async Task OnInitializedAsync()
    {
        issue = await BookIssueService.GetBookIssueByIdAsync(Id);

        loading = false;
    }

    private async Task ReturnBookDetails()
    {
        try
        {
            saving = true;

            await BookIssueService.ReturnBookAsync(Id);

            message = "Book returned successfully.";

            await Task.Delay(1000);

            Navigation.NavigateTo("/bookissues");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/bookissues");
    }

}