@page "/bookissues/history"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize]

@inject BookIssueService BookIssueService
@inject NavigationManager Navigation

<PageTitle>Book Issue History</PageTitle>

<div class="card card-secondary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title">

                <i class="bi bi-clock-history"></i>

                Book Issue History

            </h3>

            <div class="d-flex align-items-center gap-2">

                <input class="form-control"
                       style="width:320px"
                       placeholder="Search Student / Registration / Book..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                <button class="btn btn-light"
                        @onclick="Back">

                    <i class="bi bi-arrow-left"></i>

                    Current Issues

                </button>

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center p-5">

                <div class="spinner-border text-secondary"></div>

                <p class="mt-3">

                    Loading History...

                </p>

            </div>
        }
        else if (!history.Any())
        {
            <div class="alert alert-warning">

                No History Found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Registration No</th>

                            <th>Student</th>

                            <th>Book Code</th>

                            <th>Book Name</th>

                            <th>Issue Date</th>

                            <th>Return Date</th>

                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in history)
                        {
                            <tr>

                                <td>

                                    <span class="badge bg-primary">

                                        @item.RegistrationNo

                                    </span>

                                </td>

                                <td>

                                    @item.StudentName

                                </td>

                                <td>

                                    @item.BookCode

                                </td>

                                <td>

                                    @item.BookName

                                </td>

                                <td>

                                    @item.IssueDate.ToShortDateString()

                                </td>

                                <td>

                                    @(item.ReturnDate?.ToShortDateString() ?? "-")

                                </td>

                                <td>

                                    @switch (item.Status)
                                    {
                                        case "Returned":
                                            <span class="badge bg-success">

                                                Returned

                                            </span>
                                            break;

                                        case "Lost":
                                            <span class="badge bg-danger">

                                                Lost

                                            </span>
                                            break;

                                        case "Damaged":
                                            <span class="badge bg-warning text-dark">

                                                Damaged

                                            </span>
                                            break;

                                        default:
                                            <span class="badge bg-secondary">

                                                @item.Status

                                            </span>
                                            break;
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<BookIssue> history = new();

    private bool loading = true;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        loading = true;

        StateHasChanged();

        var result = await BookIssueService.GetPagedHistoryAsync(
            CurrentPage,
            PageSize,
            string.IsNullOrWhiteSpace(searchText)
                ? null
                : searchText);

        history = result.Items.ToList();

        TotalPages = result.TotalPages;

        TotalRecords = result.TotalRecords;

        loading = false;

        StateHasChanged();
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadHistory();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadHistory();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        CurrentPage = 1;

        await LoadHistory();
    }

    private void Back()
    {
        Navigation.NavigateTo("/bookissues");
    }

}