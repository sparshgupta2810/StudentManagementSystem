@page "/books/inactive/{Id:int}"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = Roles.Admin + "," + Roles.Librarian)]

@inject BookService BookService
@inject NavigationManager Navigation

<PageTitle>Inactive Book</PageTitle>

<div class="card card-danger shadow">

    <div class="card-header">

        <h3 class="card-title">

            <i class="bi bi-exclamation-triangle-fill"></i>

            Make Book Inactive

        </h3>

    </div>

    @if (loading)
    {
        <div class="card-body text-center p-5">

            <div class="spinner-border text-danger"></div>

            <p class="mt-3">

                Loading Book...

            </p>

        </div>
    }
    else if (book == null)
    {
        <div class="card-body">

            <div class="alert alert-danger">

                Book not found.

            </div>

        </div>
    }
    else
    {
        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="alert alert-success">

                    <i class="bi bi-check-circle-fill"></i>

                    @message

                </div>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">

                    <i class="bi bi-exclamation-triangle-fill"></i>

                    @error

                </div>
            }

            <div class="alert alert-warning">

                <h5>

                    Are you sure?

                </h5>

                <hr />

                <p>

                    <strong>Book Code :</strong>

                    @book.BookCode

                </p>

                <p>

                    <strong>Book Name :</strong>

                    @book.BookName

                </p>

                <p>

                    <strong>Author :</strong>

                    @book.Author

                </p>

                <p>

                    <strong>Total Copies :</strong>

                    @book.TotalCopies

                </p>

                <p>

                    <strong>Available Copies :</strong>

                    @book.AvailableCopies

                </p>

                <hr />

                <p class="mb-0 text-danger">

                    This book will be moved to
                    <strong>Book History</strong>.

                </p>

            </div>

        </div>

        <div class="card-footer">

            <button class="btn btn-danger"
                    @onclick="MakeInactive"
                    disabled="@saving">

                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }

                <i class="bi bi-x-circle"></i>

                Make Inactive

            </button>

            <button class="btn btn-secondary ms-2"
                    @onclick="Back">

                <i class="bi bi-arrow-left-circle"></i>

                Cancel

            </button>

        </div>
    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Book? book;

    private bool loading = true;

    private bool saving;

    private string? message;

    private string? error;

    protected override async Task OnInitializedAsync()
    {
        book = await BookService.GetBookByIdAsync(Id);

        loading = false;
    }

    private async Task MakeInactive()
    {
        try
        {
            saving = true;

            await BookService.InactivateBookAsync(Id);

            message = "Book moved to history successfully.";

            await Task.Delay(800);

            Navigation.NavigateTo("/books");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/books");
    }

}