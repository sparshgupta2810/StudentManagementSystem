@page "/books/edit/{Id:int}"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = Roles.Admin + "," + Roles.Librarian)]

@inject BookService BookService
@inject NavigationManager Navigation

<PageTitle>Edit Book</PageTitle>

<div class="card card-warning shadow">

    <div class="card-header">

        <h3 class="card-title">

            <i class="bi bi-pencil-square"></i>

            Edit Book

        </h3>

    </div>

    @if (loading)
    {
        <div class="card-body text-center p-5">

            <div class="spinner-border text-warning"></div>

            <p class="mt-3">

                Loading Book...

            </p>

        </div>
    }
    else if (book == null)
    {
        <div class="card-body">

            <div class="alert alert-danger">

                Book not found.

            </div>

        </div>
    }
    else
    {
        <EditForm Model="book"
                  OnValidSubmit="UpdateBook">

            <DataAnnotationsValidator />

            <ValidationSummary class="text-danger" />

            <div class="card-body">

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-success">

                        <i class="bi bi-check-circle-fill"></i>

                        @message

                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger">

                        <i class="bi bi-exclamation-triangle-fill"></i>

                        @error

                    </div>
                }

                <div class="row">

                    <div class="col-md-4">

                        <div class="mb-3">

                            <label class="form-label">

                                Book Code

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="book.BookCode" />

                            <ValidationMessage For="@(() => book.BookCode)" />

                        </div>

                    </div>

                    <div class="col-md-8">

                        <div class="mb-3">

                            <label class="form-label">

                                Book Name

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="book.BookName" />

                            <ValidationMessage For="@(() => book.BookName)" />

                        </div>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">

                                Author

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="book.Author" />

                            <ValidationMessage For="@(() => book.Author)" />

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="mb-3">

                            <label class="form-label">

                                Total Copies

                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="book.TotalCopies" />

                            <ValidationMessage For="@(() => book.TotalCopies)" />

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="mb-3">

                            <label class="form-label">

                                Available Copies

                            </label>

                            <input class="form-control"
                                   value="@book.AvailableCopies"
                                   readonly />

                            <small class="text-muted">

                                Updated automatically through Book Issue / Return.

                            </small>

                        </div>

                    </div>

                </div>

                <div class="form-check mt-2">

                    <InputCheckbox class="form-check-input"
                                   @bind-Value="book.IsActive" />

                    <label class="form-check-label">

                        Book Active

                    </label>

                </div>

            </div>

            <div class="card-footer">

                <button type="submit"
                        class="btn btn-warning"
                        disabled="@saving">

                    @if (saving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }

                    <i class="bi bi-save"></i>

                    Update

                </button>

                <button type="button"
                        class="btn btn-secondary ms-2"
                        @onclick="Back">

                    <i class="bi bi-arrow-left-circle"></i>

                    Back

                </button>

            </div>

        </EditForm>
    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Book? book;

    private bool loading = true;

    private bool saving;

    private string? message;

    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadBook();
    }

    private async Task LoadBook()
    {
        loading = true;

        book = await BookService.GetBookByIdAsync(Id);

        loading = false;
    }

    private async Task UpdateBook()
    {
        try
        {
            saving = true;

            message = string.Empty;
            error = string.Empty;

            if (book == null)
                return;

            // Calculate currently issued books
            int issuedBooks = book.TotalCopies - book.AvailableCopies;

            // Prevent Total Copies from becoming less than issued books
            if (book.TotalCopies < issuedBooks)
            {
                error = $"Cannot reduce Total Copies below {issuedBooks}. There are currently {issuedBooks} issued books.";

                return;
            }

            await BookService.UpdateBookAsync(book);

            message = "Book updated successfully.";

            await Task.Delay(800);

            Navigation.NavigateTo("/books");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/books");
    }

}