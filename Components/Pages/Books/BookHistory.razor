@page "/books/history"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = Roles.Admin + "," + Roles.Librarian)]

@inject BookService BookService
@inject NavigationManager Navigation

<PageTitle>Book History</PageTitle>

<div class="card card-secondary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title">

                <i class="bi bi-clock-history"></i>

                Book History

            </h3>

            <div class="d-flex align-items-center gap-2">

                <input class="form-control"
                       style="width:320px"
                       placeholder="Search Book Code, Name or Author..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                <button class="btn btn-light"
                        @onclick="Back">

                    <i class="bi bi-arrow-left"></i>

                    Active Books

                </button>

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center py-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Book History...

                </p>

            </div>
        }
        else if (!books.Any())
        {
            <div class="alert alert-success">

                <i class="bi bi-check-circle-fill"></i>

                No inactive books found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Book Code</th>

                            <th>Book Name</th>

                            <th>Author</th>

                            <th>Total Copies</th>

                            <th>Available</th>

                            <th>Status</th>

                            <th width="130">

                                Action

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in books)
                        {
                            <tr>

                                <td>

                                    <span class="badge bg-primary">

                                        @item.BookCode

                                    </span>

                                </td>

                                <td>

                                    @item.BookName

                                </td>

                                <td>

                                    @item.Author

                                </td>

                                <td>

                                    @item.TotalCopies

                                </td>

                                <td>

                                    @item.AvailableCopies

                                </td>

                                <td>

                                    <span class="badge bg-danger">

                                        Inactive

                                    </span>

                                </td>

                                <td>

                                    <button class="btn btn-success"
                                            @onclick="() => RestoreBook(item.Id)">

                                        <i class="bi bi-arrow-counterclockwise"></i>

                                        Restore

                                    </button>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<Book> books = new();

    private bool loading = true;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        loading = true;

        StateHasChanged();

        var result = await BookService.GetPagedBookHistoryAsync(
            CurrentPage,
            PageSize,
            string.IsNullOrWhiteSpace(searchText)
                ? null
                : searchText);

        books = result.Items.ToList();

        TotalPages = result.TotalPages;

        TotalRecords = result.TotalRecords;

        loading = false;

        StateHasChanged();
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadHistory();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadHistory();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;

        CurrentPage = 1;

        await LoadHistory();
    }

    private async Task RestoreBook(int id)
    {
        var result = await BookService.RestoreBookAsync(id);

        if (result)
        {
            await LoadHistory();
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/books");
    }

}