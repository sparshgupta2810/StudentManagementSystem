@page "/books"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize]

@inject BookService BookService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Books</PageTitle>

<div class="card card-primary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title mb-2 mb-md-0">

                <i class="bi bi-book-fill"></i>

                Books

            </h3>

            <div class="d-flex align-items-center gap-2 flex-wrap">

                <input class="form-control"
                       style="width:320px"
                       placeholder="Search Book Code, Name or Author..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                @if (isAdmin)
                {
                    <button class="btn btn-secondary"
                            @onclick="History">

                        <i class="bi bi-clock-history"></i>

                        Book History

                    </button>

                    <button class="btn btn-light"
                            @onclick="AddBook">

                        <i class="bi bi-plus-circle"></i>

                        Add Book

                    </button>
                }

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center py-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Books...

                </p>

            </div>
        }
        else if (!books.Any())
        {
            <div class="alert alert-warning">

                No Books Found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Book Code</th>

                            <th>Book Name</th>

                            <th>Author</th>

                            <th>Total</th>

                            <th>Available</th>

                            <th>Status</th>

                            @if (isAdmin)
                            {
                                <th width="180">

                                    Action

                                </th>
                            }

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in books)
                        {
                            <tr>

                                <td>

                                    <span class="badge bg-primary">

                                        @item.BookCode

                                    </span>

                                </td>

                                <td>

                                    @item.BookName

                                </td>

                                <td>

                                    @item.Author

                                </td>

                                <td>

                                    <span class="badge bg-info">

                                        @item.TotalCopies

                                    </span>

                                </td>

                                <td>

                                    @if (item.AvailableCopies == 0)
                                    {
                                        <span class="badge bg-danger">

                                            @item.AvailableCopies

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">

                                            @item.AvailableCopies

                                        </span>
                                    }

                                </td>

                                <td>

                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">

                                            Active

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">

                                            Inactive

                                        </span>
                                    }

                                </td>

                                @if (isAdmin)
                                {
                                    <td>

                                        <button class="btn btn-warning btn-sm"
                                                @onclick="() => EditBook(item.Id)">

                                            <i class="bi bi-pencil-square"></i>

                                            Edit

                                        </button>

                                        <button class="btn btn-danger btn-sm ms-2"
                                                @onclick="() => InactiveBook(item.Id)">

                                            <i class="bi bi-x-circle"></i>

                                            Remove

                                        </button>

                                    </td>
                                }

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<Book> books = new();

    private bool loading = true;

    private bool isAdmin;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        isAdmin =
            authState.User.IsInRole(Roles.Admin) ||
            authState.User.IsInRole(Roles.Librarian);

        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        loading = true;

        StateHasChanged();

        var result = await BookService.GetPagedBooksAsync(
            CurrentPage,
            PageSize,
            string.IsNullOrWhiteSpace(searchText)
                ? null
                : searchText);

        books = result.Items.ToList();

        TotalPages = result.TotalPages;

        TotalRecords = result.TotalRecords;

        loading = false;

        StateHasChanged();
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadBooks();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadBooks();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;

        CurrentPage = 1;

        await LoadBooks();
    }

    private void AddBook()
    {
        Navigation.NavigateTo("/books/add");
    }

    private void EditBook(int id)
    {
        Navigation.NavigateTo($"/books/edit/{id}");
    }

    private void InactiveBook(int id)
    {
        Navigation.NavigateTo($"/books/inactive/{id}");
    }

    private void History()
    {
        Navigation.NavigateTo("/books/history");
    }

}