@page "/students/history"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize]

@inject StudentService StudentService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Student History</PageTitle>

<div class="card card-secondary shadow">

    <div class="card-header">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <h3 class="card-title">

                <i class="bi bi-clock-history"></i>

                Student History

            </h3>

            <div class="d-flex gap-2">

                <input class="form-control"
                       style="width:320px"
                       placeholder="Search Registration, Name or Email..."
                       value="@searchText"
                       @oninput="OnSearchChanged" />

                <button class="btn btn-light btn-sm"
                        @onclick="Back">

                    <i class="bi bi-arrow-left"></i>

                    Active Students

                </button>

            </div>

        </div>

    </div>

    <div class="card-body">

        @if (loading)
        {
            <div class="text-center py-5">

                <div class="spinner-border text-primary"></div>

                <p class="mt-3">

                    Loading Student History...

                </p>

            </div>
        }
        else if (!students.Any())
        {
            <div class="alert alert-success">

                <i class="bi bi-check-circle-fill"></i>

                No inactive students found.

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Registration No</th>

                            <th>Student Name</th>

                            <th>Department</th>

                            <th>Email</th>

                            <th>Phone</th>

                            <th>Status</th>

                            @if (canRestore)
                            {
                                <th width="140">

                                    Action

                                </th>
                            }

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in students)
                        {
                            <tr>

                                <td>

                                    <span class="badge bg-primary">

                                        @item.RegistrationNo

                                    </span>

                                </td>

                                <td>

                                    <strong>

                                        @item.FirstName
                                        @item.MiddleName
                                        @item.LastName

                                    </strong>

                                </td>

                                <td>

                                    @item.DepartmentName

                                </td>

                                <td>

                                    @item.Email

                                </td>

                                <td>

                                    @item.PhoneNumber

                                </td>

                                <td>

                                    <span class="badge bg-danger">

                                        Inactive

                                    </span>

                                </td>

                                @if (canRestore)
                                {
                                    <td>

                                        <button class="btn btn-success btn-sm"
                                                @onclick="() => RestoreStudent(item.Id)">

                                            <i class="bi bi-arrow-counterclockwise"></i>

                                            Restore

                                        </button>

                                    </td>
                                }

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

    <div class="card-footer">

        <Pagination CurrentPage="@CurrentPage"
                    TotalPages="@TotalPages"
                    TotalRecords="@TotalRecords"
                    PageSize="@PageSize"
                    OnPageChanged="LoadPage"
                    OnPageSizeChanged="ChangePageSize" />

    </div>

</div>

@code {

    private List<Student> students = new();

    private bool loading = true;

    private bool canRestore;

    private int CurrentPage = 1;

    private int PageSize = 15;

    private int TotalPages;

    private int TotalRecords;

    private string searchText = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider
            .GetAuthenticationStateAsync();

        canRestore =
            authState.User.IsInRole(Roles.Admin) ||
            authState.User.IsInRole(Roles.Teacher);

        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        loading = true;

        var result = await StudentService.GetPagedStudentHistoryAsync(
            CurrentPage,
            PageSize,
            string.IsNullOrWhiteSpace(searchText)
                ? null
                : searchText);

        students = result.Items.ToList();

        TotalPages = result.TotalPages;

        TotalRecords = result.TotalRecords;

        loading = false;
    }

    private async Task LoadPage(int page)
    {
        CurrentPage = page;

        await LoadHistory();
    }

    private async Task ChangePageSize(int size)
    {
        PageSize = size;

        CurrentPage = 1;

        await LoadHistory();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        CurrentPage = 1;

        await LoadHistory();
    }

    private async Task RestoreStudent(int id)
    {
        if (await StudentService.RestoreStudentAsync(id))
        {
            await LoadHistory();
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/students");
    }

}