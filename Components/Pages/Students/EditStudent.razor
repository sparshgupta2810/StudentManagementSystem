@page "/students/edit/{Id:int}"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = $"{Roles.Admin},{Roles.Teacher}")]

@inject StudentService StudentService
@inject DepartmentService DepartmentService
@inject NavigationManager Navigation

<PageTitle>Edit Student</PageTitle>

<div class="card card-warning shadow">

    <div class="card-header">

        <h3 class="card-title">

            <i class="bi bi-pencil-square"></i>

            Edit Student

        </h3>

    </div>

    @if (loading)
    {
        <div class="card-body text-center p-5">

            <div class="spinner-border text-warning"></div>

            <p class="mt-3">

                Loading Student...

            </p>

        </div>
    }
    else if (student == null)
    {
        <div class="card-body">

            <div class="alert alert-danger">

                Student not found.

            </div>

        </div>
    }
    else
    {

        <EditForm Model="student"
                  OnValidSubmit="UpdateStudent">

            <DataAnnotationsValidator />

            <ValidationSummary class="text-danger" />

            <div class="card-body">

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-success">

                        @message

                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger">

                        @error

                    </div>
                }

                <div class="row">

                    <div class="col-md-4">

                        <div class="mb-3">

                            <label class="form-label">

                                Registration Number

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="student.RegistrationNo" />

                        </div>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4">

                        <div class="mb-3">

                            <label class="form-label">

                                First Name

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="student.FirstName" />

                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="mb-3">

                            <label class="form-label">

                                Middle Name

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="student.MiddleName" />

                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="mb-3">

                            <label class="form-label">

                                Last Name

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="student.LastName" />

                        </div>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">

                                Email

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="student.Email" />

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">

                                Phone Number

                            </label>

                            <InputText class="form-control"
                                       @bind-Value="student.PhoneNumber" />

                        </div>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4">

                        <div class="mb-3">

                            <label class="form-label">

                                Gender

                            </label>

                            <InputSelect class="form-select"
                                         @bind-Value="student.Gender">

                                <option value="">Select Gender</option>

                                <option>Male</option>

                                <option>Female</option>

                                <option>Other</option>

                            </InputSelect>

                        </div>

                    </div>

                    <div class="col-md-8">

                        <div class="mb-3">

                            <label class="form-label">

                                Department

                            </label>

                            <InputSelect class="form-select"
                                         @bind-Value="student.DepartmentId">

                                @foreach (var department in departments)
                                {
                                    <option value="@department.Id">

                                        @department.DepartmentName

                                    </option>
                                }

                            </InputSelect>

                        </div>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">

                                Date Of Birth

                            </label>

                            <InputDate class="form-control"
                                       @bind-Value="student.DateOfBirth" />

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">

                                Admission Date

                            </label>

                            <InputDate class="form-control"
                                       @bind-Value="student.AdmissionDate" />

                        </div>

                    </div>

                </div>

                <div class="mb-3">

                    <label class="form-label">

                        Address

                    </label>

                    <InputTextArea class="form-control"
                                   rows="3"
                                   @bind-Value="student.Address" />

                </div>

                <div class="form-check">

                    <InputCheckbox class="form-check-input"
                                   @bind-Value="student.IsActive" />

                    <label class="form-check-label">

                        Student Active

                    </label>

                </div>

            </div>

            <div class="card-footer">

                <button class="btn btn-warning"
                        type="submit"
                        disabled="@saving">

                    @if (saving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }

                    <i class="bi bi-save"></i>

                    Update

                </button>

                <button class="btn btn-secondary ms-2"
                        type="button"
                        @onclick="Back">

                    <i class="bi bi-arrow-left-circle"></i>

                    Back

                </button>

            </div>

        </EditForm>

    }

</div>

                        @code {

    [Parameter]
    public int Id { get; set; }

    private Student? student;

    private List<Department> departments = new();

    private bool loading = true;

    private bool saving;

    private string? message;

    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadDepartments();

        await LoadStudent();
    }

    private async Task LoadDepartments()
    {
        departments = (await DepartmentService
            .GetAllDepartmentsAsync())
            .OrderBy(d => d.DepartmentName)
            .ToList();
    }

    private async Task LoadStudent()
    {
        loading = true;

        student = await StudentService.GetStudentByIdAsync(Id);

        loading = false;
    }

    private async Task UpdateStudent()
    {
        try
        {
            saving = true;

            message = string.Empty;
            error = string.Empty;

            if (student == null)
            {
                error = "Student not found.";
                return;
            }

            if (student.DepartmentId == 0)
            {
                error = "Please select a Department.";
                return;
            }

            if (string.IsNullOrWhiteSpace(student.Gender))
            {
                error = "Please select Gender.";
                return;
            }

            await StudentService.UpdateStudentAsync(student);

            message = "Student updated successfully.";

            await Task.Delay(800);

            Navigation.NavigateTo("/students");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/students");
    }

}