@page "/students/inactive/{Id:int}"

@using Microsoft.AspNetCore.Authorization
@using StudentManagementSystemApp.Constants
@using StudentManagementSystemApp.Models
@using StudentManagementSystemApp.Services

@attribute [Authorize(Roles = $"{Roles.Admin},{Roles.Teacher}")]

@inject StudentService StudentService
@inject NavigationManager Navigation

<PageTitle>Inactive Student</PageTitle>

<div class="card card-danger shadow">

    <div class="card-header">

        <h3 class="card-title">

            <i class="bi bi-person-x-fill"></i>

            Make Student Inactive

        </h3>

    </div>

    @if (loading)
    {
        <div class="card-body text-center p-5">

            <div class="spinner-border text-danger"></div>

            <p class="mt-3">

                Loading Student...

            </p>

        </div>
    }
    else if (student == null)
    {
        <div class="card-body">

            <div class="alert alert-danger">

                Student not found.

            </div>

        </div>
    }
    else
    {

        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="alert alert-success">

                    <i class="bi bi-check-circle-fill"></i>

                    @message

                </div>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">

                    <i class="bi bi-exclamation-triangle-fill"></i>

                    @error

                </div>
            }

            <div class="alert alert-warning">

                <h5>

                    Are you sure?

                </h5>

                <hr />

                <p>

                    <strong>Registration No :</strong>

                    @student.RegistrationNo

                </p>

                <p>

                    <strong>Name :</strong>

                    @student.FirstName
                    @student.MiddleName
                    @student.LastName

                </p>

                <p>

                    <strong>Department :</strong>

                    @student.DepartmentName

                </p>

                <p>

                    <strong>Email :</strong>

                    @student.Email

                </p>

                <p>

                    <strong>Phone :</strong>

                    @student.PhoneNumber

                </p>

                <hr />

                <p class="text-danger mb-0">

                    This student will be moved to
                    <strong>Student History</strong>.

                </p>

            </div>

        </div>

        <div class="card-footer">

            <button class="btn btn-danger"
                    @onclick="MakeInactive"
                    disabled="@saving">

                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }

                <i class="bi bi-person-x-fill"></i>

                Make Inactive

            </button>

            <button class="btn btn-secondary ms-2"
                    @onclick="Back">

                <i class="bi bi-arrow-left-circle"></i>

                Cancel

            </button>

        </div>

    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Student? student;

    private bool loading = true;

    private bool saving;

    private string? message;

    private string? error;

    protected override async Task OnInitializedAsync()
    {
        student = await StudentService.GetStudentByIdAsync(Id);

        loading = false;
    }

    private async Task MakeInactive()
    {
        try
        {
            saving = true;

            await StudentService.InactivateStudentAsync(Id);

            message = "Student moved to history successfully.";

            await Task.Delay(800);

            Navigation.NavigateTo("/students");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void Back()
    {
        Navigation.NavigateTo("/students");
    }

}